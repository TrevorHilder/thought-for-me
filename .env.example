# ── Supabase ────────────────────────────────────────────────────────────────
# Your Supabase project URL (from Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — has full database access; keep secret, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anon/public key — safe to expose to client-side code
SUPABASE_ANON_KEY=your-anon-key

# ── Resend (optional — email delivery notifications) ─────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=re_your_resend_api_key

# ── Cron job security ────────────────────────────────────────────────────────
# A secret token used to protect the /api/cron/deliver endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret

# ── App ─────────────────────────────────────────────────────────────────────
# The canonical URL of your deployed app (used in email links)
APP_URL=https://your-app.vercel.app
